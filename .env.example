# Postgres (app state)
PRAVI_DB_URL=postgresql+asyncpg://pravi:pravi@localhost:5433/pravi

# Temporal
PRAVI_TEMPORAL_HOST=localhost:7233
PRAVI_TEMPORAL_NAMESPACE=default
PRAVI_TEMPORAL_TASK_QUEUE_FEATURES=pravi-features
PRAVI_TEMPORAL_TASK_QUEUE_LLM=pravi-llm

# Where per-ticket git worktrees are provisioned.
PRAVI_WORKTREE_BASE=~/.pravi/worktrees
# Where GitHub repos are lazily cloned the first time a ticket targets them.
# PRAVI_CLONE_BASE=~/.pravi/repos

# Dev-agent sandbox backend (see ADR 0003). Only "local" exists today
# (host filesystem + git worktree); the seam is in place for docker/remote.
# PRAVI_SANDBOX_BACKEND=local

# Logging
PRAVI_LOG_LEVEL=INFO

# --- Architect (planning) ---
# Provider for the architect agent.
#   claude  — uses claude-agent-sdk with read-only tools (Read/Grep/Glob/WebFetch).
#   litellm — single-shot completion via LiteLLM; works with OpenAI, Gemini,
#             Bedrock, Ollama, etc. Context is pre-packed into the prompt.
PRAVI_ARCHITECT_PROVIDER=claude
# Optional model pin — the default for every architect mode. None = provider
# default. LiteLLM examples:
#   gpt-5
#   gemini/gemini-2.5-pro
#   bedrock/anthropic.claude-3-5-sonnet-20240620-v1:0
#   ollama/llama3.2
# PRAVI_ARCHITECT_MODEL=
# Per-mode overrides on top of PRAVI_ARCHITECT_MODEL. Clarify defaults to
# Haiku 4.5 (cheap, latency-sensitive); decompose/draft default to the
# provider default.
# PRAVI_ARCHITECT_CLARIFY_MODEL=claude-haiku-4-5-20251001
# PRAVI_ARCHITECT_DECOMPOSE_MODEL=
# PRAVI_ARCHITECT_DRAFT_MODEL=
PRAVI_ARCHITECT_MAX_WALL_SECONDS=300
PRAVI_ARCHITECT_MAX_TURNS=30
PRAVI_ARCHITECT_MAX_COST_USD=1.0

# --- Dev agent (executes the plan) ---
# Only "claude" is implemented today.
PRAVI_DEV_PROVIDER=claude
# PRAVI_DEV_MODEL=
PRAVI_DEV_MAX_WALL_SECONDS=1800
PRAVI_DEV_MAX_TURNS=50
PRAVI_DEV_MAX_COST_USD=5.0

# Default cumulative spend ceiling per ticket, in USD. Unset = unlimited.
# Used when neither the ticket nor any ancestor sets a ceiling explicitly;
# enforced pre-flight before each dev run. See docs/user-guide/budgets.md.
# PRAVI_TICKET_COST_CEILING_USD=

# --- API keys (conventional env vars; SDKs read them directly) ---
#
# ANTHROPIC_API_KEY — pay-per-token billing via console.anthropic.com.
#   Pravi reads this from .env via `apply_anthropic_auth()` and exports it
#   to `os.environ` so claude-agent-sdk finds it.
#
#   If unset, the SDK falls back to your local `claude login` session — i.e.
#   your Claude.ai Pro/Max subscription quota. That's a separate account
#   from console.anthropic.com; you can't get an API key from a Pro/Max
#   account. To get one, sign up at console.anthropic.com.
#
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Web UI base URL the CLI links to. Default is the FastAPI port; switch to
# http://localhost:5173 if you usually have Vite dev running.
PRAVI_WEB_URL_BASE=http://localhost:8765

# --- GitHub OAuth (Connect GitHub button + auto-PR creation) ---
# Register an OAuth App at https://github.com/settings/developers:
#   Homepage URL: http://localhost:8765
#   Callback URL: http://localhost:8765/api/auth/github/callback
# Then paste the client id + a freshly-generated client secret here.
PRAVI_GITHUB_OAUTH_CLIENT_ID=
PRAVI_GITHUB_OAUTH_CLIENT_SECRET=
# PRAVI_GITHUB_OAUTH_REDIRECT_URI=http://localhost:8765/api/auth/github/callback
# PRAVI_GITHUB_OAUTH_SCOPES=repo,read:user
# PRAVI_GITHUB_OAUTH_SUCCESS_REDIRECT=http://localhost:8765/

# PR posture. When false (default), pravi opens PRs "ready for review" so
# they land straight in your review queue. Set true to open as draft and
# promote manually.
# PRAVI_PR_OPEN_AS_DRAFT=false

# --- Cloudflare (optional — "new repo + Pages deploy" flow) ---
# Alternative to env vars: click "Connect Cloudflare" in the new-repo modal
# and paste a token there (stored in the DB). Env vars act as a fallback.
#
# Token: https://dash.cloudflare.com/profile/api-tokens — needs
#   `Account → Cloudflare Pages → Edit` on the target account.
# Account ID: shown on your Cloudflare dashboard's account home page.
#
# One-time browser step: authorize Cloudflare's GitHub App on the account
# that owns your repos (Cloudflare dashboard → Workers & Pages → Connect
# to Git) — Pages builds won't trigger without it.
# PRAVI_CLOUDFLARE_API_TOKEN=
# PRAVI_CLOUDFLARE_ACCOUNT_ID=
