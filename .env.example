# Postgres (app state)
PRAVI_DB_URL=postgresql+asyncpg://pravi:pravi@localhost:5433/pravi

# Temporal
PRAVI_TEMPORAL_HOST=localhost:7233
PRAVI_TEMPORAL_NAMESPACE=default
PRAVI_TEMPORAL_TASK_QUEUE_FEATURES=pravi-features
PRAVI_TEMPORAL_TASK_QUEUE_LLM=pravi-llm

# Worktree base
PRAVI_WORKTREE_BASE=~/.pravi/worktrees

# Target repos managed by pravi (comma-separated absolute paths)
PRAVI_TARGET_REPOS=/Users/cavanpage/repos/blissful-infra

# Logging
PRAVI_LOG_LEVEL=INFO

# Anthropic API key (used by claude-agent-sdk in the dev activity).
# Required for Slice 1+ when actually running the developer agent.
ANTHROPIC_API_KEY=

# Per-dev-run budget guardrails (override via env if needed).
PRAVI_DEV_MAX_WALL_SECONDS=1800
PRAVI_DEV_MAX_TURNS=50
PRAVI_DEV_MAX_COST_USD=5.0
